<Window x:Class="XMacroBridge.App.AppMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XMacro Bridge"
        Width="460"
        SizeToContent="Height"
        MinHeight="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="14" /><RowDefinition Height="Auto" /><RowDefinition Height="22" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <Path x:Name="KindIcon" Width="18" Height="18" Margin="0,0,10,0" Style="{StaticResource TablerIconPathStyle}" />
            <TextBlock x:Name="HeadingText" VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" />
        </StackPanel>
        <TextBlock x:Name="MessageText" Grid.Row="2" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
        <StackPanel Grid.Row="4" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button x:Name="CancelButton" MinWidth="88" Margin="0,0,8,0" Click="Cancel_Click" Content="取消" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" Visibility="Collapsed" />
            <Button x:Name="SecondaryButton" MinWidth="88" Margin="0,0,8,0" Click="Secondary_Click" Content="另存为" Style="{StaticResource SecondaryButtonStyle}" Visibility="Collapsed" />
            <Button x:Name="PrimaryButton" MinWidth="88" Click="Primary_Click" Content="确定" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
