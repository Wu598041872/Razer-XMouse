<Window x:Class="XMacroBridge.App.EventEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑宏事件"
        Width="500"
        MinWidth="460"
        MinHeight="340"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="编辑事件" />
        <TextBlock x:Name="EventSummaryText" Grid.Row="2" Style="{StaticResource CaptionStyle}" />

        <Border Grid.Row="4" Padding="16" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid x:Name="DelayEditor" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="8" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <TextBlock Text="固定延时" />
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <TextBox x:Name="DelayTextBox" Width="150" AutomationProperties.Name="固定延时毫秒"
                                 Style="{StaticResource ParameterTextBoxStyle}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="毫秒" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="KeyboardEditor" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="8" /><RowDefinition Height="Auto" /><RowDefinition Height="12" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <TextBlock Text="键盘事件" />
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionStyle}" Text="按键（点击后直接按键）" />
                            <TextBox x:Name="VirtualKeyTextBox" Margin="0,5,0,0"
                                     AutomationProperties.Name="捕获事件键盘按键"
                                     AutomationProperties.HelpText="点击输入框后直接按下 A、Alt 等目标键"
                                     IsReadOnly="True"
                                     PreviewKeyDown="VirtualKeyTextBox_PreviewKeyDown"
                                     Style="{StaticResource ParameterTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource CaptionStyle}" Text="状态" /><ComboBox x:Name="KeyTransitionComboBox" Margin="0,5,0,0" DisplayMemberPath="DisplayName" /></StackPanel>
                    </Grid>
                    <CheckBox x:Name="ExtendedKeyCheckBox" Grid.Row="4" Content="扩展键编码" />
                </Grid>

                <Grid x:Name="MouseEditor" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="8" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <TextBlock Text="鼠标事件" />
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Style="{StaticResource CaptionStyle}" Text="鼠标按钮" /><ComboBox x:Name="MouseButtonComboBox" Margin="0,5,0,0" DisplayMemberPath="DisplayName" /></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource CaptionStyle}" Text="状态" /><ComboBox x:Name="MouseTransitionComboBox" Margin="0,5,0,0" DisplayMemberPath="DisplayName" /></StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid x:Name="ValidationPanel"
              Grid.Row="6"
              Visibility="Collapsed"
              AutomationProperties.LiveSetting="Assertive">
            <Grid.ColumnDefinitions><ColumnDefinition Width="16" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Path Width="16" Height="16" Data="{StaticResource ErrorIconGeometry}" Stroke="{DynamicResource ErrorBrush}" Style="{StaticResource TablerIconPathStyle}" />
            <TextBlock x:Name="ValidationText" Grid.Column="2" Foreground="{DynamicResource ErrorBrush}" FontSize="12" TextWrapping="Wrap" />
        </Grid>
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="88" /><ColumnDefinition Width="8" /><ColumnDefinition Width="88" /></Grid.ColumnDefinitions>
            <Button x:Name="CancelButton" Grid.Column="1" Click="Cancel_Click" Content="取消" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" />
            <Button x:Name="SaveButton" Grid.Column="3" Click="Save_Click" Content="保存" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" />
        </Grid>
    </Grid>
</Window>
