<Window x:Class="XMacroBridge.App.MacroLibraryEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保存到宏库"
        Width="720"
        Height="620"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="DialogHeading" FontSize="18" FontWeight="SemiBold" Text="保存到宏库" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource CaptionStyle}" Text="宏名称" />
                <TextBox x:Name="EntryNameTextBox" Margin="0,6,0,0" MaxLength="128" TextChanged="Input_Changed" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Style="{StaticResource CaptionStyle}" Text="保存分组" />
                <ComboBox x:Name="GroupComboBox" Margin="0,6,0,0" SelectionChanged="Input_Changed" />
            </StackPanel>
        </Grid>

        <TextBlock x:Name="TextLabel" Grid.Row="4" Style="{StaticResource CaptionStyle}" Text="XMouse 宏文本" />
        <TextBox x:Name="MacroTextBox"
                 Grid.Row="6"
                 Height="Auto"
                 MinHeight="300"
                 Padding="12,10"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalContentAlignment="Top"
                 HorizontalScrollBarVisibility="Disabled"
                 VerticalScrollBarVisibility="Auto"
                 TextChanged="Input_Changed" />

        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" MinWidth="88" Click="Cancel_Click" Content="取消" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" />
            <Button x:Name="ConfirmButton" Grid.Column="3" MinWidth="100" Click="Confirm_Click" Content="保存" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" />
        </Grid>
    </Grid>
</Window>
