<UserControl x:Class="XMacroBridge.App.MacroLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="宏库页面">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="LibraryItemStyle" TargetType="ListBoxItem">
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="2,0,0,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="2">
                            <Grid>
                                <Border x:Name="SelectionAccent" Width="3" Margin="-12,-8,0,-8"
                                        HorizontalAlignment="Left" Background="{DynamicResource RazerGreenBrush}" Visibility="Collapsed" />
                                <ContentPresenter />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource RowHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectedGreenMutedBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource RazerGreenBrush}" />
                                <Setter TargetName="SelectionAccent" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="LibraryInsertBefore">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource RazerGreenBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1,3,1,1" />
                            </Trigger>
                            <Trigger Property="Tag" Value="LibraryInsertAfter">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource RazerGreenBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1,1,1,3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12,16">
        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="8" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="205" MinWidth="180" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" MinWidth="260" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" MinWidth="260" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Padding="14" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Height="32">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="分组" />
                    <Button Grid.Column="1" MinWidth="42" Click="CreateGroup_Click" Content="新增" IsEnabled="{Binding CanModifyLibrary}" Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>
                <ListBox x:Name="GroupList"
                         Grid.Row="2"
                         AutomationProperties.Name="宏库分组"
                         ItemsSource="{Binding GroupOptions}"
                         SelectedValuePath="Key"
                         SelectedValue="{Binding SelectedScope, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="6,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource CaptionStyle}" Text="{Binding ItemCount}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="4">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="6" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Button Click="RenameGroup_Click" Content="重命名" IsEnabled="{Binding CanRenameSelectedGroup}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Grid.Column="2" Click="DeleteGroup_Click" Content="删除空组" IsEnabled="{Binding CanDeleteSelectedGroup}" Style="{StaticResource DangerButtonStyle}" />
                    </Grid>
                    <Button Margin="0,6,0,0" Click="EmptyTrash_Click" Content="清空回收站" IsEnabled="{Binding CanEmptyTrash}" Style="{StaticResource DangerButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid Height="32" Margin="14,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="6" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="XMouse 宏文本" />
                    <Button Grid.Column="1" Click="NewText_Click" Content="新建" IsEnabled="{Binding CanModifyLibrary}" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="3" Click="ImportTextFiles_Click" Content="导入" IsEnabled="{Binding CanModifyLibrary}" Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>
                <Grid Grid.Row="1">
                    <ListBox x:Name="XMouseList"
                             Margin="8,0"
                             AutomationProperties.Name="XMouse 宏文本列表"
                             ItemsSource="{Binding XMouseItems}"
                             SelectedItem="{Binding SelectedXMouseItem, Mode=TwoWay}"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="LibraryList_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="LibraryList_PreviewMouseMove"
                             DragOver="LibraryList_DragOver"
                             DragLeave="LibraryList_DragLeave"
                             Drop="LibraryList_Drop"
                             SelectionChanged="LibraryList_SelectionChanged"
                             MouseDoubleClick="OpenSelected_Click"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource LibraryItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" />
                                    <Viewbox Grid.Column="1" Width="21" Height="21" Margin="10,0,2,0" VerticalAlignment="Center" IsHitTestVisible="False" AutomationProperties.Name="">
                                        <Path Data="{DynamicResource StarFilledIconGeometry}" Fill="{DynamicResource RazerGreenBrush}" Stretch="Uniform">
                                            <Path.Style><Style TargetType="Path"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsFavorite}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Path.Style>
                                        </Path>
                                    </Viewbox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel x:Name="XMouseEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="220">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers><DataTrigger Binding="{Binding HasXMouseItems}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}" Text="暂无 XMouse 宏" />
                        <TextBlock Margin="0,4,0,10" Style="{StaticResource EmptyStateCaptionStyle}" Text="新建宏文本，或导入已有 TXT 文件。" />
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <Button MinWidth="68" Click="NewText_Click" Content="新建" IsEnabled="{Binding CanModifyLibrary}" Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Margin="6,0,0,0" MinWidth="68" Click="ImportTextFiles_Click" Content="导入" IsEnabled="{Binding CanModifyLibrary}" Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <TextBlock Grid.Row="2" Margin="14,7,14,0" Style="{StaticResource CaptionStyle}" Text="{Binding XMousePreviewText}"
                           TextTrimming="CharacterEllipsis" ToolTip="{Binding XMousePreviewText}" />
                <Grid x:Name="XMouseActionPanel" Grid.Row="3" Margin="12,10" Visibility="{Binding HasSelectedXMouseItem, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="6" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Button Tag="xmouse" Click="OpenSelected_Click" Content="在转换区打开" IsEnabled="{Binding CanUseSelectedXMouseItem}" Style="{StaticResource PrimaryButtonStyle}" />
                    <UniformGrid Grid.Row="2" Columns="4">
                        <Button Tag="xmouse" Margin="0,0,3,0" Click="EditText_Click" Content="编辑" IsEnabled="{Binding CanUseSelectedXMouseItem}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Tag="xmouse" Margin="3,0" Click="CopyText_Click" Content="复制" IsEnabled="{Binding CanUseSelectedXMouseItem}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Tag="xmouse" Margin="3,0" Click="Favorite_Click" Content="收藏" IsEnabled="{Binding CanUseSelectedXMouseItem}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Tag="xmouse" Margin="3,0,0,0" Click="MoreItemActions_Click" Content="更多" Style="{StaticResource SecondaryButtonStyle}" />
                    </UniformGrid>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid Height="32" Margin="14,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="雷蛇宏 XML" />
                    <Button Grid.Column="1" Click="ImportXmlFiles_Click" Content="导入 XML" IsEnabled="{Binding CanModifyLibrary}" Style="{StaticResource PrimaryButtonStyle}" />
                </Grid>
                <Grid Grid.Row="1">
                    <ListBox x:Name="RazerList"
                             Margin="8,0"
                             AutomationProperties.Name="雷蛇 XML 宏列表"
                             ItemsSource="{Binding RazerItems}"
                             SelectedItem="{Binding SelectedRazerItem, Mode=TwoWay}"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="LibraryList_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="LibraryList_PreviewMouseMove"
                             DragOver="LibraryList_DragOver"
                             DragLeave="LibraryList_DragLeave"
                             Drop="LibraryList_Drop"
                             SelectionChanged="LibraryList_SelectionChanged"
                             MouseDoubleClick="OpenSelected_Click"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource LibraryItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" />
                                    <Viewbox Grid.Column="1" Width="21" Height="21" Margin="10,0,2,0" VerticalAlignment="Center" IsHitTestVisible="False" AutomationProperties.Name="">
                                        <Path Data="{DynamicResource StarFilledIconGeometry}" Fill="{DynamicResource RazerGreenBrush}" Stretch="Uniform">
                                            <Path.Style><Style TargetType="Path"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsFavorite}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Path.Style>
                                        </Path>
                                    </Viewbox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel x:Name="RazerEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="220">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers><DataTrigger Binding="{Binding HasRazerItems}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}" Text="暂无雷蛇宏 XML" />
                        <TextBlock Margin="0,4,0,10" Style="{StaticResource EmptyStateCaptionStyle}" Text="导入 XML 文件后可直接打开到转换区。" />
                        <Button MinWidth="84" HorizontalAlignment="Center" Click="ImportXmlFiles_Click" Content="导入 XML" IsEnabled="{Binding CanModifyLibrary}" Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </Grid>
                <TextBlock Grid.Row="2" Margin="14,7,14,0" Style="{StaticResource CaptionStyle}" Text="{Binding RazerPreviewText}"
                           TextTrimming="CharacterEllipsis" ToolTip="{Binding RazerPreviewText}" />
                <Grid x:Name="RazerActionPanel" Grid.Row="3" Margin="12,10" Visibility="{Binding HasSelectedRazerItem, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="6" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Button Tag="razer" Click="OpenSelected_Click" Content="在转换区打开" IsEnabled="{Binding CanUseSelectedRazerItem}" Style="{StaticResource PrimaryButtonStyle}" />
                    <UniformGrid Grid.Row="2" Columns="3">
                        <Button Tag="razer" Margin="0,0,3,0" Click="RevealSelected_Click" Content="打开位置" IsEnabled="{Binding CanUseSelectedRazerItem}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Tag="razer" Margin="3,0" Click="Favorite_Click" Content="收藏" IsEnabled="{Binding CanUseSelectedRazerItem}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Tag="razer" Margin="3,0,0,0" Click="MoreItemActions_Click" Content="更多" Style="{StaticResource SecondaryButtonStyle}" />
                    </UniformGrid>
                </Grid>
            </Grid>
        </Border>
        <Border x:Name="LibraryStatusBar" Grid.Row="2" Grid.ColumnSpan="5" MinHeight="32" Padding="10,6"
                Background="{DynamicResource SubtlePanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
            <Grid>
                <TextBlock AutomationProperties.LiveSetting="Polite" Style="{StaticResource CaptionStyle}"
                           Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding StatusText}" />
                <ProgressBar Height="3" Margin="0,22,0,0" VerticalAlignment="Top" IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
