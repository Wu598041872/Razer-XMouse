<Window x:Class="XMacroBridge.App.MacroRenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重命名宏"
        Width="480"
        Height="230"
        MinWidth="420"
        MinHeight="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />
        <TextBlock Grid.Row="2"
                   Style="{StaticResource CaptionStyle}"
                   Text="名称不能为空，保存后将用于列表显示和本地文件名。" />
        <TextBox x:Name="MacroNameTextBox"
                 Grid.Row="4"
                 AutomationProperties.Name="宏的新名称"
                 TabIndex="0"
                 Height="32"
                 MaxLength="128"
                 Padding="10,5"
                 TextChanged="MacroNameTextBox_TextChanged" />

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1"
                    AutomationProperties.Name="取消重命名"
                    TabIndex="1"
                    MinWidth="88"
                    Click="Cancel_Click"
                    Content="取消"
                    IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button x:Name="RenameButton"
                    Grid.Column="3"
                    AutomationProperties.Name="确认重命名宏"
                    TabIndex="2"
                    MinWidth="88"
                    Click="Rename_Click"
                    Content="重命名"
                    IsDefault="True"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </Grid>
    </Grid>
</Window>
