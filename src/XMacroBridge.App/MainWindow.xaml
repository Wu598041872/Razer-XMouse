                    <Grid Grid.Row="6">
                        <TextBlock Style="{StaticResource CaptionStyle}" Text="工作区宏" />
                        <TextBlock HorizontalAlignment="Right" Style="{StaticResource CaptionStyle}" Text="{Binding MacroCountText}" />
                    </Grid>
                    <ListBox x:Name="MacroList" Grid.Row="8" AutomationProperties.Name="工作区宏列表"
                             TabIndex="3" Focusable="True" IsTabStop="True" KeyboardNavigation.TabNavigation="Once"
                             PreviewMouseRightButtonDown="MacroList_PreviewMouseRightButtonDown"
                             ItemsSource="{Binding Macros}" SelectedItem="{Binding SelectedMacro, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource MacroListItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem AutomationProperties.Name="重命名宏" Header="重命名…" Click="RenameMacro_Click" />
                                <MenuItem AutomationProperties.Name="修改宏文本" Header="修改宏文本…" Click="ModifyMacroText_Click" />
                                <MenuItem AutomationProperties.Name="删除宏" Header="删除" Click="DeleteMacro_Click" IsEnabled="{Binding CanDeleteMacro}" Tag="Danger" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" />
                                        <TextBlock Margin="0,3,0,0" Style="{StaticResource CaptionStyle}" Text="{Binding SourceFormat, TargetNullValue=未知来源}" />
                                    </StackPanel>
                                    <Path Grid.Column="1" Width="12" Height="12" Margin="8,0,0,0" VerticalAlignment="Center"
                                          Data="{DynamicResource ChevronRightIconGeometry}" Style="{StaticResource TablerIconPathStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="300" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="38" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="48" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Grid MinWidth="0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="事件时间线" />
                                <TextBlock Grid.Column="1" Margin="10,2,0,0" MinWidth="0" VerticalAlignment="Center"
                                           Style="{StaticResource CaptionStyle}" Text="{Binding SelectedMacroSummary}"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding SelectedMacroSummary}" />
                            </Grid>
                            <StackPanel x:Name="EventSearchHost" Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal"
                                        Visibility="{Binding HasSelectedMacro, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBox x:Name="EventSearchTextBox" Width="190" AutomationProperties.Name="搜索时间线事件" TabIndex="32"
                                         MaxLength="128" Tag="搜索事件、序号或详情"
                                         PreviewKeyDown="EventSearchTextBox_PreviewKeyDown"
                                         Style="{StaticResource SearchTextBoxStyle}"
                                         Text="{Binding EventSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                                <Button x:Name="FindPreviousEventButton" Margin="6,0,0,0" MinWidth="54" AutomationProperties.Name="定位上一个时间线搜索结果"
                                        TabIndex="33" Click="FindPreviousEvent_Click" Content="上一项" IsEnabled="{Binding CanFindPreviousEvent}" Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="{Binding HasEventSearchText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button x:Name="FindNextEventButton" Margin="6,0,0,0" MinWidth="54" AutomationProperties.Name="定位下一个时间线搜索结果"
                                        TabIndex="34" Click="FindNextEvent_Click" Content="下一项" IsEnabled="{Binding CanFindNextEvent}" Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="{Binding HasEventSearchText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock x:Name="EventSearchResultTextBlock" Margin="8,0,0,0" MinWidth="54" VerticalAlignment="Center"
                                           AutomationProperties.Name="时间线搜索结果计数" Style="{StaticResource CaptionStyle}" Text="{Binding EventSearchResultText}"
                                           Visibility="{Binding HasEventSearchText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>

                        <Border x:Name="TimelineSelectionToolbar" Grid.Row="1" Padding="10,8" Background="{DynamicResource ToolbarSectionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,1"
                                Visibility="{Binding HasSelectedMacro, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <WrapPanel ItemHeight="36" VerticalAlignment="Center">
                                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="选择事件后可编辑">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers><DataTrigger Binding="{Binding HasSelectedEvents}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Margin="12,0,2,0" VerticalAlignment="Center" Foreground="{DynamicResource RazerGreenBrush}"
                                           Style="{StaticResource TabularNumberTextStyle}" Text="{Binding SelectedEventCountText}"
                                           Visibility="{Binding HasSelectedEvents, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Rectangle Width="1" Height="20" Margin="10,0" VerticalAlignment="Center" Fill="{DynamicResource BorderBrush}"
                                           Visibility="{Binding HasSelectedEvents, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button x:Name="EditEventButton" MinWidth="54" AutomationProperties.Name="编辑选中的时间线事件" TabIndex="14"
                                        Click="EditEvent_Click" Content="编辑" IsEnabled="{Binding CanEditSelectedEvent}" Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="{Binding HasSelectedEvents, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button x:Name="CopyEventButton" Margin="6,0,0,0" MinWidth="48" AutomationProperties.Name="复制选中的时间线事件" TabIndex="15"
                                        Click="CopyEvent_Click" Content="复制" IsEnabled="{Binding CanCopyEvent}" Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="{Binding HasSelectedEvents, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button x:Name="DeleteEventButton" Margin="6,0,0,0" MinWidth="48" AutomationProperties.Name="删除选中的时间线事件" TabIndex="16"
                                        Click="DeleteEvent_Click" Content="删除" IsEnabled="{Binding CanDeleteEvent}" Style="{StaticResource DangerButtonStyle}"
                                        Visibility="{Binding HasSelectedEvents, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button x:Name="MoveEventUpButton" Margin="10,0,0,0" MinWidth="48" AutomationProperties.Name="向上移动选中的时间线事件" TabIndex="17"
                                        Click="MoveEventUp_Click" Content="上移" IsEnabled="{Binding CanMoveEventUp}" Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="{Binding HasSelectedEvents, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button x:Name="MoveEventDownButton" Margin="6,0,0,0" MinWidth="48" AutomationProperties.Name="向下移动选中的时间线事件" TabIndex="18"
                                        Click="MoveEventDown_Click" Content="下移" IsEnabled="{Binding CanMoveEventDown}" Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="{Binding HasSelectedEvents, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button x:Name="AddOperationButton" Margin="10,0,0,0" MinWidth="82"
                                        AutomationProperties.Name="展开或收起添加操作参数" TabIndex="19"
                                        Click="ToggleAddOperation_Click" Content="添加操作" IsEnabled="{Binding CanInsertEvent}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button x:Name="UndoButton" Margin="10,0,0,0" MinWidth="48" AutomationProperties.Name="撤销时间线编辑" TabIndex="20"
                                        Click="Undo_Click" Content="撤销" IsEnabled="{Binding CanUndo}" Style="{StaticResource SecondaryButtonStyle}" ToolTip="{Binding UndoAvailabilityText}" />
                                <Button x:Name="RedoButton" Margin="6,0,0,0" MinWidth="48" AutomationProperties.Name="重做时间线编辑" TabIndex="21"
                                        Click="Redo_Click" Content="重做" IsEnabled="{Binding CanRedo}" Style="{StaticResource SecondaryButtonStyle}" ToolTip="{Binding RedoAvailabilityText}" />
                                <Rectangle Width="1" Height="20" Margin="10,0" VerticalAlignment="Center" Fill="{DynamicResource BorderBrush}" Visibility="Collapsed" />
                                <TextBlock Margin="0,0,5,0" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="全部延时" Visibility="Collapsed" />
                                <TextBox x:Name="DelayScalePercentTextBox" Width="54" AutomationProperties.Name="全部延时缩放百分比" TabIndex="25"
                                         Style="{StaticResource ParameterTextBoxStyle}"
                                         Visibility="Collapsed"
                                         Text="{Binding DelayScalePercentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="5,0" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="%" Visibility="Collapsed" />
                                <Button x:Name="ScaleDelaysButton" MinWidth="48" AutomationProperties.Name="批量缩放全部延时" TabIndex="26"
                                        Click="ScaleDelays_Click" Content="缩放" IsEnabled="{Binding CanScaleDelays}" Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="Collapsed" />
                            </WrapPanel>
                        </Border>

                        <Border x:Name="TimelineInsertionToolbar" Grid.Row="2" Padding="10,8" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                Visibility="{Binding IsAddOperationPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <WrapPanel ItemHeight="36" VerticalAlignment="Center">
                                <TextBlock Margin="0,0,5,0" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="延时" />
                                <TextBox x:Name="NewDelayMillisecondsTextBox" Width="62" AutomationProperties.Name="新插入延时毫秒" TabIndex="12"
                                         Style="{StaticResource ParameterTextBoxStyle}"
                                         Text="{Binding NewDelayMillisecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="5,0,6,0" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="ms" />
                                <Button x:Name="InsertDelayButton" MinWidth="72" AutomationProperties.Name="在选中事件之后插入固定延时" TabIndex="13"
                                        Click="InsertDelay_Click" Content="插入延时" IsEnabled="{Binding CanInsertDelay}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Rectangle Width="1" Height="20" Margin="10,0" VerticalAlignment="Center" Fill="{DynamicResource BorderBrush}" />
                                <TextBlock Margin="0,0,5,0" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="键盘按键" />
                                <TextBox x:Name="VirtualKeyTextBox" Width="82" AutomationProperties.Name="捕获新键盘事件按键" TabIndex="21"
                                         AutomationProperties.HelpText="点击输入框后直接按下目标键"
                                         IsReadOnly="True"
                                         Style="{StaticResource ParameterTextBoxStyle}"
                                         PreviewKeyDown="VirtualKeyTextBox_PreviewKeyDown"
                                         Text="{Binding NewVirtualKeyDisplayText, Mode=OneWay}" />
                                <ComboBox x:Name="KeyTransitionSelector" Width="70" Margin="6,0,0,0" AutomationProperties.Name="新键盘事件按下或释放" TabIndex="22"
                                          ItemsSource="{Binding InputTransitionOptions}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedKeyTransition, Mode=TwoWay}" />
                                <CheckBox x:Name="ExtendedKeyCheckBox" Margin="8,0" VerticalAlignment="Center" AutomationProperties.Name="新键盘事件使用扩展键编码" TabIndex="23"
                                          Content="扩展键" IsChecked="{Binding NewKeyIsExtended, Mode=TwoWay}" />
                                <Button x:Name="InsertKeyEventButton" MinWidth="72" AutomationProperties.Name="插入参数化键盘事件" TabIndex="24"
                                        Click="InsertKeyEvent_Click" Content="插入键盘" IsEnabled="{Binding CanInsertEvent}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Rectangle Width="1" Height="20" Margin="10,0" VerticalAlignment="Center" Fill="{DynamicResource BorderBrush}" />
                                <TextBlock Margin="0,0,5,0" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="鼠标" />
                                <ComboBox x:Name="MouseButtonSelector" Width="104" AutomationProperties.Name="新鼠标事件按钮" TabIndex="27"
                                          ItemsSource="{Binding MouseButtonOptions}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedMouseButton, Mode=TwoWay}" />
                                <ComboBox x:Name="MouseTransitionSelector" Width="70" Margin="6,0,0,0" AutomationProperties.Name="新鼠标事件按下或释放" TabIndex="28"
                                          ItemsSource="{Binding InputTransitionOptions}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedMouseTransition, Mode=TwoWay}" />
                                <Button x:Name="InsertMouseEventButton" Margin="6,0,0,0" MinWidth="72" AutomationProperties.Name="插入参数化鼠标事件" TabIndex="29"
                                        Click="InsertMouseEvent_Click" Content="插入鼠标" IsEnabled="{Binding CanInsertEvent}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Rectangle Width="1" Height="20" Margin="10,0" VerticalAlignment="Center" Fill="{DynamicResource BorderBrush}" Visibility="Collapsed" />
                                <TextBlock Margin="0,0,5,0" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="延时" Visibility="Collapsed" />
                                <TextBox x:Name="DelayMillisecondsTextBox" Width="68" AutomationProperties.Name="选中事件延时毫秒" TabIndex="30"
                                         Style="{StaticResource ParameterTextBoxStyle}"
                                         Visibility="Collapsed"
                                         Text="{Binding DelayMillisecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button x:Name="ApplyDelayButton" Margin="6,0,0,0" MinWidth="48" AutomationProperties.Name="应用选中事件延时" TabIndex="31"
                                        Click="ApplyDelay_Click" Content="应用" IsEnabled="{Binding CanUpdateSelectedDelay}" Style="{StaticResource SecondaryButtonStyle}"
                                        Visibility="Collapsed" />
                            </WrapPanel>
                        </Border>

                        <Border x:Name="NestedMacroToolbar" Grid.Row="3" Padding="10,6"
                                Background="{DynamicResource SubtlePanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                Visibility="{Binding ShowNestedMacroTools, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="嵌套宏目标" />
                                <ComboBox x:Name="NestedMacroTargetSelector" Grid.Column="2" MinWidth="160" MaxWidth="420"
                                          HorizontalAlignment="Stretch" AutomationProperties.Name="选择已导入的嵌套宏目标" TabIndex="30"
                                          TextSearch.TextPath="Name"
                                          ItemsSource="{Binding AvailableReferenceTargets}" DisplayMemberPath="Name"
                                          Text="{Binding SelectedReferenceTarget.Name, Mode=OneWay}"
                                          SelectedItem="{Binding SelectedReferenceTarget, Mode=TwoWay}"
                                          ToolTip="{Binding SelectedReferenceTarget.Name}" />
                                <Button x:Name="BindNestedMacroButton" Grid.Column="4" MinWidth="72"
                                        AutomationProperties.Name="将选中的嵌套宏事件绑定到目标宏" TabIndex="31"
                                        Click="BindNestedMacro_Click" Content="绑定宏" IsEnabled="{Binding CanBindReferenceTarget}" Style="{StaticResource SecondaryButtonStyle}"
                                        ToolTip="先选中时间线中的嵌套宏事件，再从下拉框选择目标" />
                                <Button x:Name="InsertNestedMacroButton" Grid.Column="6" MinWidth="72"
                                        AutomationProperties.Name="插入已导入宏作为嵌套宏事件" TabIndex="32"
                                        Click="InsertNestedMacro_Click" Content="插入宏" IsEnabled="{Binding CanInsertMacroReference}" Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>
                        </Border>

                        <DataGrid x:Name="EventTimeline" Grid.Row="4" AutomationProperties.Name="宏事件时间线"
                                  TabIndex="6" Focusable="True" IsTabStop="True"
                                  KeyboardNavigation.TabNavigation="Once" KeyboardNavigation.DirectionalNavigation="Contained"
                                  ItemsSource="{Binding Events}" SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                                  SelectionMode="Extended" SelectionUnit="FullRow" SelectionChanged="EventTimeline_SelectionChanged"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserResizeRows="False" CanUserResizeColumns="False" CanUserSortColumns="False" HeadersVisibility="None"
                                  Background="{DynamicResource PanelBrush}" BorderThickness="0" GridLinesVisibility="None"
                                  ColumnHeaderStyle="{StaticResource TimelineHeaderStyle}" CellStyle="{StaticResource TimelineCellStyle}"
                                  RowStyle="{StaticResource TimelineRowStyle}" RowHeaderWidth="0"
                                  EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" ClipToBounds="True"
                                  AllowDrop="True" PreviewMouseLeftButtonDown="EventTimeline_PreviewMouseLeftButtonDown"
                                  PreviewMouseLeftButtonUp="EventTimeline_PreviewMouseLeftButtonUp"
                                  Loaded="EventTimeline_Loaded" SizeChanged="EventTimeline_SizeChanged"
                                  PreviewMouseMove="EventTimeline_PreviewMouseMove" DragOver="EventTimeline_DragOver"
                                  DragLeave="EventTimeline_DragLeave" Drop="EventTimeline_Drop"
                                  PreviewMouseRightButtonDown="EventTimeline_PreviewMouseRightButtonDown">
                            <DataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="编辑事件…" Click="EditEvent_Click" IsEnabled="{Binding CanEditSelectedEvent}" />
                                    <Separator />
                                    <MenuItem Header="复制" Click="CopyEvent_Click" IsEnabled="{Binding CanCopyEvent}" />
                                    <MenuItem Header="删除" Click="DeleteEvent_Click" IsEnabled="{Binding CanDeleteEvent}" Tag="Danger" />
                                    <Separator />
                                    <MenuItem Header="上移" Click="MoveEventUp_Click" IsEnabled="{Binding CanMoveEventUp}" />
                                    <MenuItem Header="下移" Click="MoveEventDown_Click" IsEnabled="{Binding CanMoveEventDown}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn x:Name="TimelineEventColumn" Width="*" MinWidth="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,0,16,0" ClipToBounds="True" ToolTip="{Binding TechnicalSummary}">
                                                <Grid ClipToBounds="True">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="32" />
                                                        <ColumnDefinition Width="40" />
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              AutomationProperties.Name="选择时间线事件"
                                                              IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}, Mode=OneWay}"
                                                              PreviewMouseLeftButtonDown="EventSelectionCheckBox_PreviewMouseLeftButtonDown"
                                                              Style="{StaticResource TimelineSelectionCheckBoxStyle}" />
                                                    <TextBlock Grid.Column="1"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Style="{StaticResource TimelineSequenceTextStyle}"
                                                               Text="{Binding DisplayNumber, StringFormat={}{0:D2}}" />
                                                    <Path Grid.Column="2" Tag="TimelineEventTypeIcon" Style="{StaticResource EventIconPathStyle}" />
                                                    <Path Grid.Column="3" Tag="TimelineTransitionIcon" Style="{StaticResource TimelineTransitionIconStyle}" />
                                                    <TextBlock Grid.Column="4" Style="{StaticResource TimelineEditorLabelStyle}" Text="{Binding EditorLabel}" />
                                                    <StackPanel Grid.Column="5" Margin="12,0,4,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                                Tag="TimelineActions"
                                                                Style="{StaticResource TimelineHoverPanelStyle}">
                                                        <Button AutomationProperties.Name="复制选中事件" Click="InlineCopyEvent_Click" Style="{StaticResource TimelineInlineButtonStyle}" ToolTip="复制选中事件">
                                                            <Viewbox><Path Style="{StaticResource TimelineCopyIconStyle}" /></Viewbox>
                                                        </Button>
                                                        <Button AutomationProperties.Name="删除选中事件" Click="InlineDeleteEvent_Click" Style="{StaticResource TimelineInlineButtonStyle}" ToolTip="删除选中事件">
                                                            <Viewbox><Path Style="{StaticResource TimelineDeleteIconStyle}" /></Viewbox>
                                                        </Button>
                                                        <Border Width="28" Height="28" Cursor="SizeAll" Tag="TimelineDragHandle" ToolTip="拖动选中事件"
                                                                PreviewMouseLeftButtonDown="EventDragHandle_PreviewMouseLeftButtonDown">
                                                            <Viewbox Margin="6"><Path Style="{StaticResource TimelineDragIconStyle}" /></Viewbox>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel x:Name="NoMacroEmptyState" Grid.Row="4" Margin="0,0,0,48" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedMacro}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Path Width="34" Height="34" HorizontalAlignment="Center"
                                  IsHitTestVisible="False"
                                  AutomationProperties.Name=""
                                  Data="{DynamicResource FileImportIconGeometry}"
                                  Stroke="{DynamicResource RazerGreenBrush}"
                                  StrokeThickness="1.5"
                                  Style="{StaticResource TablerIconPathStyle}" />
                            <TextBlock Margin="0,12,0,0" Style="{StaticResource EmptyStateTitleStyle}" Text="导入宏后开始编辑" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource EmptyStateCaptionStyle}"
                                       Text="支持雷云 4、Synapse4 和 X-Mouse 宏；所有解析与转换均在本机完成。" />
                            <StackPanel Margin="0,16,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button MinWidth="96" Click="ImportFiles_Click" Content="选择文件" Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Margin="8,0,0,0" MinWidth="104" Click="ImportText_Click" Content="输入宏文本" Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="EmptyMacroState" Grid.Row="4" Margin="0,0,0,48" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="380">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasSelectedMacro}" Value="True" />
                                                <Condition Binding="{Binding HasTimelineEvents}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Path Width="30" Height="30" HorizontalAlignment="Center"
                                  IsHitTestVisible="False"
                                  AutomationProperties.Name=""
                                  Data="{DynamicResource InfoIconGeometry}"
                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                  Style="{StaticResource TablerIconPathStyle}" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource EmptyStateTitleStyle}" Text="当前宏没有事件" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource EmptyStateCaptionStyle}"
                                       Text="使用上方的延时、键盘或鼠标工具添加第一个事件。" />
                        </StackPanel>
                    </Grid>
                </Border>

                <GridSplitter x:Name="TimelineDiagnosticSplitter" Grid.Row="1" AutomationProperties.Name="调整事件时间线与兼容性报告大小"
                              Height="8" TabIndex="7" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"
                              Visibility="{Binding HasSelectedMacro, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Focusable="True" IsTabStop="True" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" ShowsPreview="True" />

                <Border x:Name="DiagnosticPanel" Grid.Row="2" MinHeight="128" MaxHeight="240" Padding="14,12" Style="{StaticResource CardStyle}"
                        Visibility="{Binding HasSelectedMacro, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="8" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="8" /><ColumnDefinition Width="130" /><ColumnDefinition Width="8" /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="兼容性与安全报告" />
                                <TextBlock Margin="10,2,0,0" VerticalAlignment="Center" Foreground="{DynamicResource RazerGreenBrush}"
                                           Style="{StaticResource TabularNumberTextStyle}" Text="{Binding DiagnosticCountText}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="筛选" />
                            <ComboBox x:Name="DiagnosticSeverityFilter" Grid.Column="3" AutomationProperties.Name="诊断严重级别筛选" TabIndex="8"
                                      ItemsSource="{Binding DiagnosticSeverityOptions}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedDiagnosticSeverity, Mode=TwoWay}" />
                            <ComboBox x:Name="DiagnosticScopeFilter" Grid.Column="5" AutomationProperties.Name="诊断来源筛选" TabIndex="9"
                                      ItemsSource="{Binding DiagnosticScopes}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedDiagnosticScope, Mode=TwoWay}" />
                        </Grid>
                        <Grid Grid.Row="2">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers><DataTrigger Binding="{Binding HasDiagnostics}" Value="False"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Path Width="24" Height="24" HorizontalAlignment="Center"
                                      IsHitTestVisible="False"
                                      AutomationProperties.Name=""
                                      Data="{DynamicResource CircleCheckIconGeometry}"
                                      Stroke="{DynamicResource SuccessBrush}"
                                      Style="{StaticResource TablerIconPathStyle}" />
                                <TextBlock Margin="0,7,0,0" Style="{StaticResource EmptyStateTitleStyle}" Text="未发现兼容性或安全问题" />
                                <TextBlock Margin="0,3,0,0" Style="{StaticResource EmptyStateCaptionStyle}" Text="当前宏已通过基础检查，可以继续导出。" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers><DataTrigger Binding="{Binding HasFilteredOutDiagnostics}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Style="{StaticResource EmptyStateTitleStyle}" Text="当前筛选没有结果" />
                                <TextBlock Margin="0,3,0,8" Style="{StaticResource EmptyStateCaptionStyle}" Text="重置筛选后可查看全部诊断。" />
                                <Button x:Name="ResetDiagnosticFiltersButton" MinWidth="88" Click="ResetDiagnosticFilters_Click" Content="重置筛选" Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                            <ScrollViewer x:Name="DiagnosticScrollViewer" AutomationProperties.Name="兼容性与安全诊断滚动区域"
                                          TabIndex="10" Focusable="True" IsTabStop="True" KeyboardNavigation.TabNavigation="None"
                                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                          Visibility="{Binding HasFilteredDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl x:Name="DiagnosticGroupList" AutomationProperties.Name="按来源分组的诊断列表" ItemsSource="{Binding DiagnosticGroups}">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="AutomationProperties.Name" Value="{Binding Title, Converter={StaticResource SafeAutomationNameConverter}, ConverterParameter=诊断来源}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,10">
                                                <Grid Margin="0,0,0,5">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}" />
                                                    <TextBlock HorizontalAlignment="Right" Style="{StaticResource CaptionStyle}" Text="{Binding CountText}" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding Diagnostics}">
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="AutomationProperties.Name">
                                                                <Setter.Value><MultiBinding StringFormat="{}{0}：{1}"><Binding Path="Code" /><Binding Path="Severity" /></MultiBinding></Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,0,4" Padding="8,6" Background="{DynamicResource DiagnosticItemBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="18" /><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                    <Path Width="13" Height="13" Data="{DynamicResource InfoIconGeometry}">
                                                                        <Path.Style>
                                                                            <Style TargetType="Path" BasedOn="{StaticResource TablerIconPathStyle}">
                                                                                <Setter Property="Stroke" Value="{DynamicResource InfoBrush}" /><Setter Property="Data" Value="{DynamicResource InfoIconGeometry}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Severity}" Value="{x:Static diagnostics:DiagnosticSeverity.Warning}"><Setter Property="Stroke" Value="{DynamicResource WarningBrush}" /><Setter Property="Data" Value="{DynamicResource WarningIconGeometry}" /></DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Severity}" Value="{x:Static diagnostics:DiagnosticSeverity.Error}"><Setter Property="Stroke" Value="{DynamicResource ErrorBrush}" /><Setter Property="Data" Value="{DynamicResource ErrorIconGeometry}" /></DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Path.Style>
                                                                    </Path>
                                                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding Code}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Code}" />
                                                                    <TextBlock Grid.Column="2" FontSize="12" Text="{Binding Message}" TextWrapping="Wrap" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
                <Border x:Name="WorkspaceStatusBar" Grid.Row="3" Padding="12,4" Background="{DynamicResource SubtlePanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="StatusTextBlock" AutomationProperties.LiveSetting="Polite"
                                       AutomationProperties.Name="{Binding StatusText, Converter={StaticResource SafeAutomationNameConverter}, ConverterParameter=操作状态}"
                                       Style="{StaticResource CaptionStyle}" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                            <ProgressBar x:Name="OperationProgress" Margin="0,4,0,0" AutomationProperties.Name="当前操作进度"
                                         Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <Button x:Name="CancelButton" Grid.Column="1" Margin="12,0,0,0" MinWidth="70" VerticalAlignment="Center"
                                AutomationProperties.Name="取消当前操作" TabIndex="11" Click="Cancel_Click" Content="取消" IsEnabled="{Binding CanCancel}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        </ScrollViewer>

        <local:MacroLibraryView x:Name="MacroLibraryContent" Grid.Row="2" Visibility="Collapsed" />

        <ScrollViewer x:Name="SettingsContent" Grid.Row="2" Visibility="Collapsed"
                      HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
        <Grid Margin="12,16" DataContext="{Binding ElementName=MacroLibraryContent, Path=DataContext}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="190" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="600" />
            </Grid.ColumnDefinitions>
            <Border Padding="12" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Margin="8,6,8,12" Style="{StaticResource SectionTitleStyle}" Text="设置分类" />
                    <ListBox x:Name="SettingsCategoryList" AutomationProperties.Name="设置分类"
                             SelectionChanged="SettingsCategoryList_SelectionChanged" SelectedIndex="0"
                             Background="Transparent" BorderThickness="0">
                        <ListBoxItem MinHeight="46" Padding="12,8" Content="宏库" />
                        <ListBoxItem MinHeight="46" Padding="12,8" Content="转换与导出" />
                        <ListBoxItem MinHeight="46" Padding="12,8" Content="工作区" />
                        <ListBoxItem MinHeight="46" Padding="12,8" Content="关于" />
                    </ListBox>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="20" Style="{StaticResource CardStyle}">
                <Grid>
                    <ScrollViewer x:Name="LibrarySettingsPanel" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel MaxWidth="760" HorizontalAlignment="Left">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="宏库" />
                            <TextBlock Margin="0,5,0,20" Style="{StaticResource CaptionStyle}" Text="管理本地宏库路径、迁移和条目行为。" />
                            <TextBlock FontWeight="SemiBold" Text="宏库保存路径" />
                            <TextBox Margin="0,8,0,0" AutomationProperties.Name="宏库保存路径" Style="{StaticResource ReadOnlyFieldStyle}" Text="{Binding RootPathDisplay, Mode=OneWay}" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button Click="ChooseLibraryRoot_Click" Content="选择路径" Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Margin="8,0,0,0" Click="OpenLibraryFolder_Click" Content="打开目录" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Margin="8,0,0,0" Click="RestoreDefaultLibraryRoot_Click" Content="恢复默认" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Margin="8,0,0,0" Click="MigrateLibrary_Click" Content="迁移宏库" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                            <Separator Margin="0,20" />
                            <CheckBox AutomationProperties.Name="删除宏时移入回收站" Content="删除宏时移入应用回收站"
                                      IsChecked="{Binding DeleteToTrash, Mode=TwoWay}" Style="{StaticResource SwitchCheckBoxStyle}" />
                            <TextBlock Margin="0,2,52,10" Style="{StaticResource CaptionStyle}" Text="关闭后，永久删除仍会要求再次确认。" TextWrapping="Wrap" />
                            <CheckBox AutomationProperties.Name="选择宏后自动加载预览" Content="选择宏后自动加载预览"
                                      IsChecked="{Binding AutoLoadPreview, Mode=TwoWay}" Style="{StaticResource SwitchCheckBoxStyle}" />
                            <TextBlock Margin="0,12,0,0" AutomationProperties.LiveSetting="Polite" Style="{StaticResource CaptionStyle}" Text="{Binding StatusText}" />
                            <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource WarningBrush}" Text="{Binding WarningsText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="ConversionSettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel MaxWidth="760" HorizontalAlignment="Left">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="转换与导出" />
                            <TextBlock Margin="0,5,0,20" Style="{StaticResource CaptionStyle}" Text="设置默认目标格式和导出后的本地行为。" />
                            <TextBlock FontWeight="SemiBold" Text="默认目标格式" />
                            <ComboBox Width="260" Margin="0,8,0,16" HorizontalAlignment="Left"
                                      ItemsSource="{Binding TargetFormatOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Key"
                                      SelectedValue="{Binding DefaultTargetFormat, Mode=TwoWay}" />
                            <TextBlock FontWeight="SemiBold" Text="同名文件处理" />
                            <ComboBox Width="260" Margin="0,8,0,16" HorizontalAlignment="Left"
                                      ItemsSource="{Binding SameNameOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Key"
                                      SelectedValue="{Binding SameNameHandling, Mode=TwoWay}" />
                            <CheckBox Content="导出前运行安全检查" IsChecked="{Binding RunSafetyCheckBeforeExport, Mode=TwoWay}" Style="{StaticResource SwitchCheckBoxStyle}" />
                            <CheckBox Margin="0,8,0,0" Content="导出完成后打开文件位置" IsChecked="{Binding OpenOutputFolderAfterExport, Mode=TwoWay}" Style="{StaticResource SwitchCheckBoxStyle}" />
                            <CheckBox Margin="0,8,0,0" Content="保留原宏名称" IsChecked="{Binding PreserveMacroName, Mode=TwoWay}" Style="{StaticResource SwitchCheckBoxStyle}" />
                            <TextBlock Margin="0,14,0,0" Style="{StaticResource CaptionStyle}" Text="安全写入、外部文件覆盖确认和阻断错误检查不会被关闭。" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="WorkspaceSettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel MaxWidth="760" HorizontalAlignment="Left">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="工作区" />
                            <TextBlock Margin="0,5,0,20" Style="{StaticResource CaptionStyle}" Text="控制启动恢复、关闭保护和时间线信息密度。" />
                            <CheckBox Content="启动时恢复上次工作区" IsChecked="{Binding RestorePreviousWorkspace, Mode=TwoWay}"
                                      Checked="RestoreWorkspaceSetting_Changed" Unchecked="RestoreWorkspaceSetting_Changed"
                                      Style="{StaticResource SwitchCheckBoxStyle}" />
                            <CheckBox Margin="0,8,0,0" Content="关闭前检查未保存修改" IsChecked="{Binding CheckUnsavedBeforeClose, Mode=TwoWay}" Style="{StaticResource SwitchCheckBoxStyle}" />
                            <Separator Margin="0,20" />
                            <TextBlock FontWeight="SemiBold" Text="时间线行密度" />
                            <ComboBox Width="260" Margin="0,8,0,16" HorizontalAlignment="Left"
                                      ItemsSource="{Binding TimelineDensityOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Key"
                                      SelectionChanged="TimelineDensity_SelectionChanged"
                                      SelectedValue="{Binding TimelineDensity, Mode=TwoWay}" />
                            <TextBlock FontWeight="SemiBold" Text="状态反馈持续时间" />
                            <ComboBox Width="260" Margin="0,8,0,0" HorizontalAlignment="Left"
                                      ItemsSource="{Binding FeedbackDurationOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Key"
                                      SelectedValue="{Binding FeedbackDurationKey, Mode=TwoWay}" />
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="AboutSettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel MaxWidth="760" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="BrandSettingsLogo" Width="46" Height="46" Margin="0,0,14,0"
                                       IsHitTestVisible="False" AutomationProperties.Name="" Source="{DynamicResource BrandLogoImage}" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontFamily="{DynamicResource DisplayFontFamily}" FontSize="18" FontWeight="SemiBold" Text="XMACRO BRIDGE" />
                                    <TextBlock Margin="0,3,0,0" Style="{StaticResource CaptionStyle}"
                                               Text="{Binding ApplicationVersion, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=版本 {0}}" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Margin="0,20,0,0" Foreground="{DynamicResource RazerGreenBrush}" Text="个人本地工具，非 Razer 官方产品" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource CaptionStyle}" Text="所有宏解析、验证、转换和宏库管理均在本机离线完成。" TextWrapping="Wrap" />
                            <Separator Margin="0,20" />
                            <TextBlock FontWeight="SemiBold" Text="设置文件位置" />
                            <TextBox Margin="0,8,0,0" Style="{StaticResource ReadOnlyFieldStyle}" Text="{Binding SettingsPath, Mode=OneWay}" />
                            <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="支持格式" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource CaptionStyle}" Text="雷云 4 宏 XML、Synapse4 宏容器、X-Mouse 宏文本与设置 XML。" TextWrapping="Wrap" />
                            <WrapPanel Margin="0,16,0,0">
                                <Button Click="OpenSettingsLocation_Click" Content="打开设置位置" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Margin="8,0,0,0" Click="OpenThirdPartyNotices_Click" Content="第三方许可说明" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>

        <Popup x:Name="TimelineDragFeedbackPopup"
               AllowsTransparency="True"
               IsHitTestVisible="False"
               Placement="RelativePoint"
               PlacementTarget="{Binding ElementName=EventTimeline}"
               StaysOpen="True">
            <Border MinWidth="170"
                    Padding="14,9"
                    Background="{DynamicResource RazerGreenBrush}"
                    CornerRadius="4">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="20" Height="20" VerticalAlignment="Center">
                        <Path Data="{DynamicResource StackIconGeometry}"
                              Stroke="{DynamicResource RazerGreenTextBrush}"
                              Style="{StaticResource TablerIconPathStyle}" />
                    </Viewbox>
                    <TextBlock x:Name="TimelineDragFeedbackTextBlock"
                               Margin="9,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource RazerGreenTextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="移动 1 个操作" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
