<Window x:Class="XMacroBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:XMacroBridge.App"
        xmlns:accessibility="clr-namespace:XMacroBridge.App.Accessibility"
        xmlns:workspace="clr-namespace:XMacroBridge.Presentation.Workspace;assembly=XMacroBridge.Presentation"
        xmlns:diagnostics="clr-namespace:XMacroBridge.Core.Diagnostics;assembly=XMacroBridge.Core"
        Title="RAZER XMACRO BRIDGE"
        Icon="Assets/XMacroBridge.ico"
        Width="1265"
        Height="813"
        MinWidth="900"
        MinHeight="500"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        AllowDrop="True"
        Loaded="Window_Loaded"
        StateChanged="Window_StateChanged"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                           ResizeBorderThickness="6"
                           GlassFrameThickness="0"
                           CornerRadius="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <accessibility:SafeAutomationNameConverter x:Key="SafeAutomationNameConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Geometry x:Key="MinimizeWindowGeometry">M2,8 H14</Geometry>
        <Geometry x:Key="MaximizeWindowGeometry">M3,3 H13 V13 H3 Z</Geometry>
        <Geometry x:Key="RestoreWindowGeometry">M5,2 H14 V11 H12 V4 H5 Z M2,5 H11 V14 H2 Z</Geometry>
        <Geometry x:Key="CloseWindowGeometry">M3,3 L13,13 M13,3 L3,13</Geometry>

        <Style x:Key="WindowCaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CaptionButtonBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CaptionButtonBorder" Property="Background" Value="{DynamicResource ControlBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CaptionButtonBorder" Property="Background" Value="{DynamicResource StrongBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowCaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseButtonBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="{DynamicResource WindowCloseHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="{DynamicResource WindowClosePressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MacroListItemStyle" TargetType="ListBoxItem">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="AutomationProperties.Name"
                    Value="{Binding Name, Converter={StaticResource SafeAutomationNameConverter}, ConverterParameter=宏}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="3,0,1,0"
                                CornerRadius="2">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource RowHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectedGreenMutedBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource RazerGreenBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource RazerGreenBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimelineHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="{DynamicResource ToolbarSectionBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style x:Key="TimelineCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>

        <Style x:Key="TimelineRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationSummary}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource StrongBorderBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedGreenMutedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource RazerGreenBrush}" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True" />
                        <Condition Property="IsMouseOver" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="{DynamicResource RazerGreenBrush}" />
                </MultiTrigger>
                <Trigger Property="Tag" Value="TimelineInsertBefore">
                    <Setter Property="BorderBrush" Value="{DynamicResource RazerGreenBrush}" />
                    <Setter Property="BorderThickness" Value="0,2,0,0" />
                </Trigger>
                <Trigger Property="Tag" Value="TimelineInsertAfter">
                    <Setter Property="BorderBrush" Value="{DynamicResource RazerGreenBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,0,2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventIconPathStyle" TargetType="Path" BasedOn="{StaticResource TablerIconPathStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stroke" Value="{DynamicResource InfoBrush}" />
            <Setter Property="Data" Value="{DynamicResource InfoIconGeometry}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding VisualKind}" Value="{x:Static workspace:MacroEventVisualKind.Keyboard}">
                    <Setter Property="Stroke" Value="{DynamicResource RazerGreenBrush}" />
                    <Setter Property="Data" Value="{DynamicResource KeyboardIconGeometry}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding VisualKind}" Value="{x:Static workspace:MacroEventVisualKind.Mouse}">
                    <Setter Property="Stroke" Value="{DynamicResource MouseEventBrush}" />
                    <Setter Property="Data" Value="{DynamicResource MouseIconGeometry}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding VisualKind}" Value="{x:Static workspace:MacroEventVisualKind.Delay}">
                    <Setter Property="Stroke" Value="{DynamicResource DelayEventBrush}" />
                    <Setter Property="Data" Value="{DynamicResource ClockIconGeometry}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding VisualKind}" Value="{x:Static workspace:MacroEventVisualKind.Warning}">
                    <Setter Property="Stroke" Value="{DynamicResource WarningBrush}" />
                    <Setter Property="Data" Value="{DynamicResource WarningIconGeometry}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding VisualKind}" Value="{x:Static workspace:MacroEventVisualKind.Error}">
                    <Setter Property="Stroke" Value="{DynamicResource ErrorBrush}" />
                    <Setter Property="Data" Value="{DynamicResource ErrorIconGeometry}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource RazerGreenBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TimelineCopyIconStyle" TargetType="Path" BasedOn="{StaticResource TablerIconPathStyle}">
            <Setter Property="Data" Value="{DynamicResource CopyIconGeometry}" />
            <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource RazerGreenBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource RazerGreenBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                    <Setter Property="Stroke" Value="{DynamicResource TextDisabledBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TimelineDeleteIconStyle" TargetType="Path" BasedOn="{StaticResource TablerIconPathStyle}">
            <Setter Property="Data" Value="{DynamicResource DeleteIconGeometry}" />
            <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource RazerGreenHoverBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource RazerGreenBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                    <Setter Property="Stroke" Value="{DynamicResource TextDisabledBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TimelineDragIconStyle" TargetType="Path" BasedOn="{StaticResource TablerIconPathStyle}">
            <Setter Property="Data" Value="{DynamicResource DragHandleGeometry}" />
            <Setter Property="Stroke" Value="{DynamicResource TextSecondaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource RazerGreenBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource RazerGreenBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TimelineEditorLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding VisualKind}" Value="{x:Static workspace:MacroEventVisualKind.Delay}">
                    <Setter Property="Foreground" Value="{DynamicResource DelayTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding VisualKind}" Value="{x:Static workspace:MacroEventVisualKind.Warning}">
                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding VisualKind}" Value="{x:Static workspace:MacroEventVisualKind.Error}">
                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource RazerGreenBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TimelineSequenceTextStyle" TargetType="TextBlock" BasedOn="{StaticResource TabularNumberTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource MonospaceFontFamily}" />
            <Setter Property="FontSize" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource RazerGreenBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TimelineTransitionIconStyle" TargetType="Path" BasedOn="{StaticResource TablerIconPathStyle}">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="StrokeThickness" Value="2.2" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TransitionSymbol}" Value="↓">
                    <Setter Property="Data" Value="{DynamicResource ArrowBarToDownIconGeometry}" />
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding TransitionSymbol}" Value="↑">
                    <Setter Property="Data" Value="{DynamicResource ArrowBarUpIconGeometry}" />
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource RazerGreenBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TimelineSelectionCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Visibility" Value="Visible" />
        </Style>

        <Style x:Key="TimelineHoverPanelStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TimelineInlineButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="WorkspaceSaveButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="18,0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WorkspaceExportButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="18,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource NavigationBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="46" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="14,0,18,0" VerticalAlignment="Center" Orientation="Horizontal">
                <Image x:Name="BrandNavigationLogo" Width="22" Height="22"
                       IsHitTestVisible="False"
                       AutomationProperties.Name=""
                       RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{DynamicResource BrandLogoImage}" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{DynamicResource DisplayFontFamily}" FontSize="13" FontWeight="SemiBold" Text="XMACRO BRIDGE" />
                </StackPanel>
                <Button x:Name="MacroNavigationButton" Grid.Column="1"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        AutomationProperties.Name="宏转换"
                        Click="MacroNavigation_Click"
                        Style="{StaticResource NavButtonStyle}"
                        Tag="Active">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Path Data="{DynamicResource KeyboardIconGeometry}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Style="{StaticResource TablerIconPathStyle}" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Text="宏转换" />
                    </StackPanel>
                </Button>
                <Button x:Name="LibraryNavigationButton" Grid.Column="2"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        AutomationProperties.Name="宏库"
                        Click="LibraryNavigation_Click"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Path Data="{DynamicResource StackIconGeometry}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Style="{StaticResource TablerIconPathStyle}" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Text="宏库" />
                    </StackPanel>
                </Button>
                <Button x:Name="SettingsNavigationButton" Grid.Column="3"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        AutomationProperties.Name="设置"
                        Click="SettingsNavigation_Click"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Path Data="{DynamicResource SettingsIconGeometry}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Style="{StaticResource TablerIconPathStyle}" />
                        <TextBlock Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Text="设置" />
                    </StackPanel>
                </Button>
                <Button x:Name="WindowMinimizeButton" Grid.Column="5"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        AutomationProperties.Name="最小化窗口"
                        Click="WindowMinimize_Click"
                        Style="{StaticResource WindowCaptionButtonStyle}"
                        ToolTip="最小化">
                    <Path Width="16" Height="16" Data="{StaticResource MinimizeWindowGeometry}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" />
                </Button>
                <Button x:Name="WindowMaximizeRestoreButton" Grid.Column="6"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        AutomationProperties.Name="最大化或还原窗口"
                        Click="WindowMaximizeRestore_Click"
                        Style="{StaticResource WindowCaptionButtonStyle}"
                        ToolTip="最大化">
                    <Path x:Name="WindowMaximizeRestoreIcon" Width="16" Height="16" Data="{StaticResource MaximizeWindowGeometry}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" />
                </Button>
                <Button x:Name="WindowCloseButton" Grid.Column="7"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        AutomationProperties.Name="关闭窗口"
                        Click="WindowClose_Click"
                        Style="{StaticResource WindowCloseButtonStyle}"
                        ToolTip="关闭">
                    <Path Width="16" Height="16" Data="{StaticResource CloseWindowGeometry}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" />
                </Button>
            </Grid>
        </Border>

        <Border x:Name="WorkspaceToolbar" Grid.Row="1" Background="{DynamicResource ToolbarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="宏转换工作区" />
                    <TextBlock Margin="0,3,0,0" Style="{StaticResource CaptionStyle}" Text="雷云 4 与 X-Mouse 宏的离线、安全转换工作区" />
                </StackPanel>
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="15" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="142" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="142" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="128" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="136" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CurrentMacroLabel" Grid.Row="0" HorizontalAlignment="Left"
                               Style="{StaticResource CaptionStyle}" Text="当前宏" />
                    <Border x:Name="CurrentMacroValueHost" Grid.Row="2" Height="34" Padding="10,0" VerticalAlignment="Bottom"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse Fill="{DynamicResource TextDisabledBrush}" />
                                <Ellipse Fill="{DynamicResource RazerGreenBrush}"
                                         Visibility="{Binding IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                            <TextBlock x:Name="CurrentMacroValueText" Grid.Column="1"
                                       HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                       FontWeight="SemiBold" TextAlignment="Left"
                                       Text="{Binding SelectedMacro.Name, TargetNullValue=尚未选择宏}"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding SelectedMacro.Name}" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TargetFormatLabel" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Left"
                               Style="{StaticResource CaptionStyle}" Text="目标格式" />
                    <ComboBox x:Name="TargetFormatSelector" Grid.Row="2" Grid.Column="2" Height="34" VerticalAlignment="Bottom"
                              HorizontalContentAlignment="Left" Background="{DynamicResource WindowBackgroundBrush}"
                              AutomationProperties.Name="目标导出格式" TabIndex="4"
                              ItemsSource="{Binding ExportFormats}" DisplayMemberPath="DisplayName" SelectedValuePath="FormatId"
                              SelectedValue="{Binding TargetFormatId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button x:Name="SaveToLibraryButton" Grid.Row="2" Grid.Column="4" Height="40" MinWidth="128"
                            AutomationProperties.Name="保存当前宏到宏库" TabIndex="6"
                            Click="SaveToLibrary_Click" Content="保存到宏库" IsEnabled="{Binding CanExport}"
                            Style="{StaticResource WorkspaceSaveButtonStyle}" ToolTip="使用当前目标格式保存到宏库" />
                    <Button x:Name="ExportButton" Grid.Row="2" Grid.Column="6" Height="40" MinWidth="136"
                            AutomationProperties.Name="安全导出当前宏" TabIndex="5"
                            Click="Export_Click" Content="安全导出" IsEnabled="{Binding CanExport}"
                            Style="{StaticResource WorkspaceExportButtonStyle}" ToolTip="{Binding ExportAvailabilityText}" />
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="LibraryToolbar" Grid.Row="1" Visibility="Collapsed"
                Background="{DynamicResource ToolbarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                DataContext="{Binding ElementName=MacroLibraryContent, Path=DataContext}">
            <Grid Margin="20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200" />
                    <ColumnDefinition Width="1.2*" MinWidth="240" MaxWidth="420" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="宏库" />
                    <TextBlock Margin="0,3,0,0" AutomationProperties.Name="宏库保存路径" Style="{StaticResource CaptionStyle}" Text="{Binding RootPathDisplay}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBox x:Name="LibrarySearchTextBox" Grid.Column="1" VerticalAlignment="Center" AutomationProperties.Name="搜索宏库"
                         Tag="搜索宏名称或分组" PreviewKeyDown="LibrarySearchTextBox_PreviewKeyDown"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
                <ComboBox Grid.Column="3" VerticalAlignment="Center" AutomationProperties.Name="宏库排序方式"
                          ItemsSource="{Binding SortOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Key"
                          SelectedValue="{Binding SelectedSort, Mode=TwoWay}" />
                <Button x:Name="RefreshLibraryButton" Grid.Column="5" MinWidth="60" VerticalAlignment="Center" Click="RefreshLibrary_Click" Content="刷新" Style="{StaticResource SecondaryButtonStyle}" />
                <Button Grid.Column="7" MinWidth="80" VerticalAlignment="Center" Click="OpenLibraryFolder_Click" Content="打开目录" Style="{StaticResource PrimaryButtonStyle}" />
            </Grid>
        </Border>

        <Border x:Name="SettingsToolbar" Grid.Row="1" Visibility="Collapsed"
                Background="{DynamicResource ToolbarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                DataContext="{Binding ElementName=MacroLibraryContent, Path=DataContext}">
            <Grid Margin="20,8">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="设置" />
                    <TextBlock Margin="0,3,0,0" Style="{StaticResource CaptionStyle}" Text="配置宏库、转换导出和工作区行为" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Margin="0,0,7,0" Fill="{DynamicResource RazerGreenBrush}" />
                    <TextBlock AutomationProperties.LiveSetting="Polite" Style="{StaticResource CaptionStyle}" Text="{Binding SettingsSaveStatus}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="WorkspaceScrollViewer"
                      Grid.Row="2"
                      AutomationProperties.Name="工作区滚动区域"
                      HorizontalContentAlignment="Stretch"
                      HorizontalScrollBarVisibility="Disabled"
                      IsTabStop="False"
                      VerticalScrollBarVisibility="Auto"
                      Loaded="WorkspaceScrollViewer_Loaded"
                      SizeChanged="WorkspaceScrollViewer_SizeChanged"
                      ScrollChanged="WorkspaceScrollViewer_ScrollChanged">
        <Grid x:Name="MacroContent"
              MinWidth="820"
              MinHeight="600"
              Margin="12,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="214" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="578" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="14" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="导入与宏列表" />
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Button x:Name="ImportFilesButton" Grid.Column="0" AutomationProperties.Name="选择宏文件" TabIndex="0"
                                Click="ImportFiles_Click" Content="选择文件" IsEnabled="{Binding CanImport}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button x:Name="ImportFolderButton" Grid.Column="2" AutomationProperties.Name="选择宏文件夹" TabIndex="1"
                                Click="ImportFolder_Click" Content="选择文件夹" IsEnabled="{Binding CanImport}" Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>
                    <Button x:Name="ImportTextButton" Grid.Row="4" AutomationProperties.Name="输入 X-Mouse 宏文本" TabIndex="2"
