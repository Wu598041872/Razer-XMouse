<Window x:Class="XMacroBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XMacro Bridge"
        Width="1080"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7">
    <Grid Margin="32">
        <Border Padding="40" Background="White" CornerRadius="24">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock FontFamily="Segoe UI Variable Display"
                           FontSize="34"
                           FontWeight="SemiBold"
                           Text="XMacro Bridge"
                           HorizontalAlignment="Center" />
                <TextBlock Margin="0,14,0,0"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="16"
                           Foreground="#6E6E73"
                           Text="工程基础已就绪，宏转换功能将在后续阶段实现。"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
