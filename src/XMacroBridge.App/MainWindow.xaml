<Window x:Class="XMacroBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XMacro Bridge"
        Width="1280"
        Height="820"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBrush}"
        AllowDrop="True"
        Closing="Window_Closing"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontFamily="Segoe UI Variable Display, Microsoft YaHei UI"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Text="XMacro Bridge" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13"
                           Text="雷云 4 与 X-Mouse 宏的离线、安全转换工作区" />
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="12,7"
                    VerticalAlignment="Center"
                    Background="#FFEAF7EE"
                    CornerRadius="12">
                <TextBlock Foreground="{StaticResource SuccessBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Text="●  本地离线处理" />
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="286" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="导入与宏列表" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Click="ImportFiles_Click"
                                Content="选择文件"
                                IsEnabled="{Binding CanImport}"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="2"
                                Click="ImportFolder_Click"
                                Content="选择文件夹"
                                IsEnabled="{Binding CanImport}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource CaptionStyle}" Text="工作区宏" />
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource CaptionStyle}"
                                   Text="{Binding MacroCountText}" />
                    </Grid>

                    <ListBox Grid.Row="6"
                             ItemsSource="{Binding Macros}"
                             SelectedItem="{Binding SelectedMacro, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="Transparent"
                                                    CornerRadius="10">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#FFF2F2F7" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SelectionBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontSize="13"
                                               FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Name}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding SourceFormat, TargetNullValue=未知来源}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="18,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="240" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource CaptionStyle}" Text="当前宏" />
                            <TextBlock Margin="0,3,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedMacro.Name, TargetNullValue=尚未选择宏}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,3,0,0"
                                       Style="{StaticResource CaptionStyle}"
                                       Text="{Binding SelectedMacroSummary}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource CaptionStyle}" Text="目标格式" />
                            <Border Margin="0,5,0,0"
                                    Padding="8,1"
                                    Background="#FFF2F2F7"
                                    BorderBrush="{StaticResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <ComboBox ItemsSource="{Binding ExportFormats}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="FormatId"
                                          SelectedValue="{Binding TargetFormatId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="3,7" />
                            </Border>
                        </StackPanel>

                        <Button Grid.Column="4"
                                MinWidth="116"
                                VerticalAlignment="Bottom"
                                Click="Export_Click"
                                Content="安全导出…"
                                IsEnabled="{Binding CanExport}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="{Binding ExportAvailabilityText}" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="18,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="事件时间线" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource CaptionStyle}"
                                       Text="只读预览 · 编辑器将在后续阶段开放" />
                        </Grid>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding Events}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#FFF0F0F2"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#66F5F5F7"
                                  RowHeaderWidth="0"
                                  ColumnHeaderHeight="34"
                                  RowHeight="36"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
                                    <Setter Property="Padding" Value="10,0" />
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="10,0" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="90" Binding="{Binding Sequence}" Header="序号" />
                                <DataGridTextColumn Width="140" Binding="{Binding Type}" Header="事件类型" />
                                <DataGridTextColumn Width="*" Binding="{Binding Details}" Header="详细信息" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="18,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="兼容性与安全报告" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource CaptionStyle}"
                                       Text="{Binding DiagnosticCountText}" />
                        </Grid>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding Diagnostics}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" Background="#FFF8F8FA" CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="138" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="信息" />
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                <Setter Property="Text" Value="警告" />
                                                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                                <Setter Property="Text" Value="错误" />
                                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1"
                                                       FontFamily="Cascadia Mono, Consolas"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding Code}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Code}" />
                                            <TextBlock Grid.Column="2"
                                                       FontSize="12"
                                                       Text="{Binding Message}"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="3" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="{Binding StatusText}" />
                                <ProgressBar Margin="0,7,0,0"
                                             Height="4"
                                             Maximum="100"
                                             Value="{Binding ProgressPercent, Mode=OneWay}"
                                             Foreground="{StaticResource AccentBrush}"
                                             Background="#FFE5E5EA" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Margin="12,0,0,0"
                                    MinWidth="72"
                                    VerticalAlignment="Bottom"
                                    Click="Cancel_Click"
                                    Content="取消"
                                    IsEnabled="{Binding CanCancel}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
